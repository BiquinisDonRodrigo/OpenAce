# ==================================================
# OpenAce — plantilla de variables de entorno
# ==================================================

# === General ===
# Zona horaria del contenedor.
TZ=Europe/Madrid

# === OpenAce / AceStream / IPFS ===
# En despliegue Docker estándar el engine AceStream vive en el mismo contenedor.
ACESTREAM_HOST=127.0.0.1
ACESTREAM_PORT=6878
ACESTREAM_IP=

# Gateway IPFS interno usado para resolver fuentes /ipfs/ e /ipns/.
IPFS_GATEWAY=http://kubo:48080

# Base SQLite persistente.
DB_PATH=/openace/checkdb/data.db

# === Seguridad / autenticación ===
# Recomendado true en cualquier despliegue compartido o accesible desde internet.
AUTH_ENABLED=true
# Clave persistente para sesiones Flask/CSRF. Genera una con:
# python -c "import secrets; print(secrets.token_urlsafe(48))"
# Si se deja vacía, OpenAce crea una en el volumen de datos.
OPENACE_SECRET_KEY=
SESSION_DURATION_HOURS=24

# === Reverse proxy ===
# false si accedes directo a http://IP:8888.
# true si hay nginx/Caddy/Traefik/Nginx Proxy Manager delante.
REVERSE_PROXY=false

# IPs desde las que Gunicorn acepta cabeceras X-Forwarded-* cuando REVERSE_PROXY=true.
# Con nginx en la misma máquina usa 127.0.0.1. Con proxy remoto/túnel, usa la IP privada del proxy.
FORWARDED_ALLOW_IPS=127.0.0.1

# URL pública opcional usada al generar playlists M3U absolutas.
# Útil con reverse proxy en VPS, túneles o proxies que no preservan bien Host/Proto.
# Déjala vacía en acceso directo por LAN.
# Ejemplo: https://openace.midominio.com
PUBLIC_BASE_URL=

# === Streaming / FFmpeg ===
# Segundos de inactividad antes de cerrar streams MPEG-TS/HLS gestionados por FFmpeg.
OPENACE_IDLE_TIMEOUT_S=180

# Tamano de lectura del pipe FFmpeg en bytes (default 64KB).
OPENACE_CHUNK_SIZE=65536

# Tamano maximo de cola por cliente MPEG-TS (items de CHUNK_SIZE bytes).
OPENACE_QUEUE_MAX=256

# Tamano del buffer del pipe del OS en bytes (default 1MB).
OPENACE_PIPE_BUFFER_SIZE=1048576

# Numero maximo de streams FFmpeg simultaneos.
OPENACE_MAX_STREAMS=32

# Timeout de iteracion del stream FFmpeg en segundos.
OPENACE_ITERATE_TIMEOUT_S=180

# Timeout de lectura/escritura FFmpeg en microsegundos.
OPENACE_FFMPEG_RW_TIMEOUT_US=120000000

# Reintentos maximos de FFmpeg por stream.
OPENACE_FFMPEG_RESTARTS=3

# Espera entre reintentos de FFmpeg en segundos.
OPENACE_FFMPEG_RESTART_BACKOFF_S=2

# Edad maxima de segmentos HLS obsoletos antes de limpieza.
OPENACE_HLS_STALE_SEGMENT_MAX_AGE_S=30

# === Tuning de streaming (Sprint 1) ===
# Duracion de segmento HLS para streams normales/VOD (segundos).
OPENACE_HLS_TIME=4
# Tamano de lista HLS para streams normales/VOD.
OPENACE_HLS_LIST_SIZE=15
# Duracion de segmento HLS para streams en vivo (mas corto = menos latencia).
OPENACE_HLS_TIME_LIVE=2
# Tamano de lista HLS para streams en vivo.
OPENACE_HLS_LIST_SIZE_LIVE=6
# Limite del buffer de real-time de FFmpeg (reduce latencia en vivo).
OPENACE_FFMPEG_RTBUFSIZE=5M

# Intervalo de polling del stat del engine cuando el stream ya esta ready (segundos).
OPENACE_STAT_POLL_READY_S=2.0
# Numero de polls consecutivos con peers==0 antes de declarar un stream como dead.
OPENACE_ZERO_PEER_DEAD_POLLS=10

# Pool de conexiones HTTP para hablar con el engine AceStream.
OPENACE_HTTP_POOL_CONNECTIONS=64
OPENACE_HTTP_POOL_MAXSIZE=128

# === Gunicorn ===
# Mantener 1 hasta mover timers/caches/FFmpeg manager a almacenamiento compartido.
GUNICORN_WORKERS=1
GUNICORN_WORKER_CONNECTIONS=2000

# === Auto-setup opcional ===
# Permite completar el primer arranque sin wizard interactivo.
OPENACE_AUTO_SETUP=false
OPENACE_ADMIN_USER=admin
OPENACE_ADMIN_PASSWORD=
OPENACE_EULA_ACCEPT=false

# === VPN (solo docker-compose.yaml / docker-compose.dev.yaml / docker-compose.vps.yaml con Gluetun) ===
# Clave privada WireGuard (obténla de tu proveedor VPN, ej. ProtonVPN).
WG_PRIVATE_KEY=your_wireguard_private_key_here

# Países para la conexión VPN (separados por coma).
ProtonCountries=switzerland,spain
